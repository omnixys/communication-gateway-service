DATABASE_URL=postgresql+asyncpg://gateway:gateway@localhost:5433/gateway
HOST=0.0.0.0
PORT=8002
LOG_LEVEL=INFO
INTERNAL_API_KEY=replace-with-internal-api-key

# Chat Service integration
CHAT_SERVICE_URL=http://localhost:8001
CHAT_SERVICE_API_KEY=
# Legacy recipientId compatibility only. V1 clients send recipientAddress.
ADDRESS_MAPPINGS={}

# Provider: Evolution API
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=your-api-key
EVOLUTION_INSTANCE_NAME=omnixys
EVOLUTION_WEBHOOK_SECRET=your-webhook-secret

# Provider: Resend
RESEND_API_KEY=re_replace-with-resend-key
RESEND_FROM_ADDRESS=Omnixys <no-reply@omnixys.com>
RESEND_BASE_URL=https://api.resend.com
RESEND_TIMEOUT=30

# Legacy providers below are not registered in the V1 runtime.
# Provider: Stalwart (SMTP)
STALWART_ENABLED=true
STALWART_PRIORITY=10
STALWART_TIMEOUT=30
STALWART_HOST=host.docker.internal
STALWART_PORT=10587
STALWART_USERNAME=service@omnixys.com
STALWART_PASSWORD=replace-with-service-account-password
STALWART_FROM_ADDRESS=service@omnixys.com
STALWART_TLS_ENABLED=true
# Development only. Keep true with a publicly trusted production certificate.
STALWART_TLS_VERIFY=false

# Provider: Twilio (placeholder)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Provider: Mailu (placeholder)
MAILU_HOST=mailu.example.com
MAILU_PORT=587
MAILU_USERNAME=user
MAILU_PASSWORD=pass

# Provider: Firebase (placeholder)
FIREBASE_CREDENTIALS_PATH=/path/to/service-account.json

# Provider: WhatsApp Cloud API (placeholder)
WHATSAPP_CLOUD_TOKEN=your-token
WHATSAPP_CLOUD_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_CLOUD_VERIFY_TOKEN=your-verify-token

# Provider: Signal (placeholder)
SIGNAL_URL=http://signal-api:8080

# Provider: Telegram (placeholder)
TELEGRAM_BOT_TOKEN=your-bot-token

# Kafka (delivery status events)
KAFKA_BROKER=localhost:9092
